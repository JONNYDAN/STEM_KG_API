# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=123456
POSTGRES_DB=stem_kg
POSTGRES_PORT=5432

# Middleware auth PostgreSQL (etechs_global)
AUTH_POSTGRES_HOST=host.docker.internal
AUTH_POSTGRES_PORT=6432
AUTH_POSTGRES_DB=etechs_global
AUTH_POSTGRES_USER=postgres
AUTH_POSTGRES_PASSWORD=postgres

# MongoDB
MONGO_HOST=localhost
MONGO_PORT=27017
MONGO_DB=stem_knowledge

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=12345678

# JWT from etechs-middleware
JWT_SECRET=dev-secret-key-change-me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
JWT_USER_ID_CLAIM=user_id
JWT_TENANT_ID_CLAIM=tenant_id
JWT_TOKEN_TYPE_CLAIM=token_type
JWT_REQUIRED_TOKEN_TYPE=access

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3039,https://ets.etechs.vn,https://eds.etechs.vn

# Gemini (optional for AI-generated explanations)
GEMINI_MODEL=gemini-2.0-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta
GEMINI_API_KEY_1=your-gemini-key-1
GEMINI_API_KEY_2=your-gemini-key-2
GEMINI_API_KEY_3=your-gemini-key-3
